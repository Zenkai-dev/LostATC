service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Allow anyone to see the public catalog
    match /items/{itemId} {
      allow read: if true;
      // Only admins can delete or edit items
      allow write: if exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // 2. ONLY admins can read the claims list
    match /claims/{claimId} {
      allow write: if true; // Public can submit
      allow read: if exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    
    // 3. Admin list protection
    match /admins/{adminId} {
      allow read: if request.auth != null;
      allow write: if false; // Only you manually via Console
    }
  }
}