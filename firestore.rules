service cloud.firestore {
  match /databases/{database}/documents {
    
    // Anyone can read the catalog and submit a claim
    match /items/{item} {
      allow read: if true;
      allow write: if false; // Only you do this manually or via admin
    }
    
    match /claims/{claim} {
      allow write: if true; // Public can submit claims
      // ONLY admins can read the claims!
      allow read: if exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    
    // Only the owner can see the admin list
    match /admins/{admin} {
      allow read: if request.auth != null;
    }
  }
}